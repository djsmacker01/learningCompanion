# Copy to `.env` and fill in real values. Never commit `.env`.

FLASK_ENV=development

# Flask session signing — required in production (see README).
SECRET_KEY=

# Supabase — run SQL in supabase/migrations/ in the Supabase SQL editor first.
# SUPABASE_KEY must be the service_role secret (Project Settings → API), not the anon key,
# so the Flask server can insert into public.users (RLS bypass).
SUPABASE_URL=
SUPABASE_KEY=

# Optional — AI-assisted features need this.
OPENAI_API_KEY=
